# =============================================================================
# APIARY PROTOCOL - GITIGNORE
# =============================================================================

# Compiler files
cache/
out/

# Ignores development broadcast logs
!/broadcast
/broadcast/*/31337/
/broadcast/**/dry-run/

# Docs
docs/

# Markdown files (keep README.md)
*.md
!README.md

# Environment files - NEVER commit these!
.env
.env.*
*.env

# Node
node_modules/
package-lock.json
yarn.lock

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Test artifacts
MerkleTreePreSaleBondWhitelistAddressesTest.txt
MerkleTreePreSaleOwners.txt
lcov.info
coverage/
test.csv
merkle-tree-output.json

# Sensitive deployment data
/cache/**/run-latest.json

# Broadcast deployment logs (contain addresses/tx hashes)
/broadcast/

# PDF documents
*.pdf

# Home directory (accidentally added)
~/

# Claude/AI tool configs
.claude/
